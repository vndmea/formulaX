{
  "name": "@formulax/renderer-katex",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "KaTeX-based renderer for FormulaX.",
  "keywords": [
    "formulax",
    "formula",
    "katex",
    "renderer",
    "math"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "unpkg": "./dist/browser/index.global.js",
  "scripts": {
    "build": "tsup --config ../../tsup.config.mjs",
    "clean": "Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue",
    "test": "vitest run packages/renderer-katex/test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@formulax/core": "workspace:*",
    "katex": "^0.16.11"
  }
}
