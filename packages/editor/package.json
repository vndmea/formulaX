{
  "name": "@formulaxjs/editor",
  "version": "0.4.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "Modern formula editor foundation for FormulaX.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vndmea/formulaX.git",
    "directory": "packages/editor"
  },
  "keywords": [
    "formulax",
    "formula",
    "math-editor",
    "editor",
    "dom"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "unpkg": "./dist/browser/index.global.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config ../../tsup.config.mjs",
    "clean": "Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue",
    "test": "vitest run --passWithNoTests packages/editor/test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@formulaxjs/core": "workspace:*",
    "@formulaxjs/renderer": "workspace:*",
    "@formulaxjs/renderer-kity": "workspace:*",
    "@formulaxjs/kity-runtime": "workspace:*"
  }
}
