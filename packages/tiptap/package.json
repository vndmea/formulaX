{
  "name": "@formulax/tiptap",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "TipTap integration adapter for FormulaX.",
  "keywords": [
    "formulax",
    "formula",
    "tiptap",
    "editor",
    "adapter"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "unpkg": "./dist/browser/index.global.js",
  "scripts": {
    "build": "tsup --config ../../tsup.config.mjs",
    "clean": "Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue",
    "test": "vitest run packages/tiptap/test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@formulax/core": "workspace:*",
    "@formulax/editor": "workspace:*"
  },
  "peerDependencies": {
    "@tiptap/core": ">=2 <4"
  },
  "peerDependenciesMeta": {
    "@tiptap/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tiptap/core": "^2.27.2"
  }
}
