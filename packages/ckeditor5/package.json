{
  "name": "@formulaxjs/ckeditor5",
  "version": "0.5.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "CKEditor 5 integration adapter for FormulaX.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vndmea/formulaX.git",
    "directory": "packages/ckeditor5"
  },
  "keywords": [
    "formulax",
    "formula",
    "ckeditor5",
    "editor",
    "adapter"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "unpkg": "./dist/index.global.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config ../../tsup.config.mjs && node ./scripts/postbuild.mjs",
    "clean": "Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@formulaxjs/core": "workspace:*",
    "@formulaxjs/editor": "workspace:*",
    "@formulaxjs/renderer": "workspace:*",
    "@formulaxjs/renderer-image": "workspace:*",
    "@formulaxjs/renderer-kity": "workspace:*"
  },
  "peerDependencies": {
    "ckeditor5": ">=42 <49"
  },
  "peerDependenciesMeta": {
    "ckeditor5": {
      "optional": true
    }
  },
  "devDependencies": {
    "ckeditor5": "^46.1.1"
  }
}
