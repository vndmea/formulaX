{
  "name": "@formulax/core",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Core data model and shared utilities for FormulaX.",
  "keywords": [
    "formulax",
    "formula",
    "math",
    "latex",
    "ast"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "unpkg": "./dist/browser/index.global.js",
  "scripts": {
    "build": "tsup --config ../../tsup.config.mjs",
    "clean": "Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue",
    "test": "vitest run packages/core/test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
