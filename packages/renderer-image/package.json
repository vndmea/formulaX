{
  "name": "@formulaxjs/renderer-image",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "PNG image rendering helpers for FormulaX rich-text adapters.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vndmea/formulaX.git",
    "directory": "packages/renderer-image"
  },
  "keywords": [
    "formulax",
    "formula",
    "renderer",
    "image",
    "png"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "unpkg": "./dist/index.global.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config ../../tsup.config.mjs",
    "clean": "Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue",
    "test": "vitest run packages/renderer-image/test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@formulaxjs/renderer": "workspace:*"
  }
}
