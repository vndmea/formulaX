{
  "name": "@formulaxjs/kity-runtime",
  "version": "0.3.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "Legacy KityFormula runtime adapter for FormulaX.",
  "keywords": [
    "formulax",
    "kityformula",
    "kity",
    "formula",
    "math-editor",
    "legacy-runtime",
    "latex",
    "svg"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles/*": "./public/assets/styles/*",
    "./theme/*": "./public/assets/theme/*",
    "./resource/*": "./public/resource/*",
    "./images/*": "./public/assets/images/*"
  },
  "files": [
    "dist",
    "public"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config ../../tsup.config.mjs",
    "clean": "Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12"
  }
}
