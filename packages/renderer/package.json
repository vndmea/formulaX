{
  "name": "@formulax/renderer",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "Static formula renderers for FormulaX rich-text adapters.",
  "keywords": [
    "formulax",
    "formula",
    "renderer",
    "svg",
    "katex"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "unpkg": "./dist/browser/index.global.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config ../../tsup.config.mjs",
    "clean": "Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue",
    "test": "vitest run packages/renderer/test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
